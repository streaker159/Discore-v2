# ── Discord ─────────────────────────────────────────────
DISCORD_TOKEN=
CLIENT_ID=
ADMIN_GUILD_ID=
BOT_OWNER_IDS=
BOT_ADMIN_IDS=

# ── Database (Supabase Postgres) ───────────────────────
# DATABASE_URL: pooled connection (pgbouncer, port 6543) for app queries
DATABASE_URL=
# DIRECT_URL: direct connection (port 5432, no pgbouncer) required for Prisma migrations
DIRECT_URL=

# ── AI (DeepSeek) ───────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Discord Monetization SKUs ───────────────────────────
DISCORD_PREMIUM_SKU_ID=
DISCORD_AI_CREDITS_SKU_ID=

# ── Misc ────────────────────────────────────────────────
DEV_REPORT_CHANNEL_ID=
NODE_ENV=development
DISABLE_JOBS=false
DEBUG_AI_TRANSLATION=false
