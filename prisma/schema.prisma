generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Guild {
  id                       String           @id
  defaultGame              String?
  timezone                 String           @default("UTC")
  allianceName             String?
  allianceLogo             String?
  themeColor               String           @default("#1a7a9e")
  scoreboardChan           String?
  adminLogChan             String?
  premiumNoticeChan        String?
  battleSignupChan         String?
  language                 String           @default("en")
  customFooter             String?
  scoreboardManagerRoleId  String?
  disAdminRoleId           String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  allianceCode             String?          @unique
  discoreAppealRoleId      String?
  discoreManagerRoleId     String?
  discoreMutedRoleId       String?
  logChannelId             String?
  maintainRolesAndChannels Boolean          @default(true)
  moderationLogChannelId   String?
  appealChannelId          String?
  appealCategoryId         String?
  eventChannelId           String?
  suggestionChannelId      String?
  supportChannelId         String?
  adminReportsChannelId    String?
  publicSuggestionVoters   Boolean          @default(false)
  onboardingSentAt         DateTime?        @db.Timestamptz(6)
  onboardingCompletedAt    DateTime?        @db.Timestamptz(6)
  onboardingSkippedAt      DateTime?        @db.Timestamptz(6)
  onboardingChannelId      String?
  announcementChannelId    String?
  aiWelcomeChannelId       String?
  automodEnabled           Boolean          @default(true)
  automodReviewChannelId   String?
  automodDefaultAction     AutoModAction    @default(REVIEW)
  appeals                  Appeal[]
  auditLogs                AuditLog[]
  autoModCases             AutoModCase[]
  autoModRules             AutoModRule[]
  battleSignups            BattleSignup[]
  events                   Event[]
  premium                  GuildPremium?
  moderationCases          ModerationCase[]
  scoreboards              Scoreboard[]
  suggestions              Suggestion[]
  userActivities           UserActivity[]

  @@index([id])
  @@index([allianceCode])
}

model GuildPremium {
  id                    String        @id @default(cuid())
  guildId               String        @unique
  tier                  Tier          @default(FREE)
  method                PremiumMethod
  stripeSubId           String?
  code                  String?
  expiresAt             DateTime?
  grantedBy             String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  entitlementId         String?
  monthlyAiAllowance    Int           @default(0)
  monthlyAiUsed         Int           @default(0)
  monthlyAiPeriodStart  DateTime?     @db.Timestamptz(6)
  monthlyAiPeriodEnd    DateTime?     @db.Timestamptz(6)
  extraAiCredits        Int           @default(0)
  serverDailyAiLimit    Int           @default(0)
  perUserDailyAiLimit   Int           @default(0)
  cooldownSeconds       Int           @default(0)
  aiEnabled             Boolean       @default(true)
  purchasedAt           DateTime?     @db.Timestamptz(6)
  lastRenewalAt         DateTime?     @db.Timestamptz(6)
  renewalCount          Int           @default(0)
  graceNotifiedAt       DateTime?     @db.Timestamptz(6)
  aiTranslationEnabled  Boolean       @default(false)
  aiWelcomeEnabled      Boolean       @default(false)
  aiWelcomeInstructions String?
  aiImageGenEnabled     Boolean       @default(false)
  perUserDailyImageGenLimit Int       @default(0)
  guild                 Guild         @relation(fields: [guildId], references: [id])

  @@index([guildId])
  @@index([expiresAt])
}

model ProcessedEntitlement {
  id             String   @id @default(cuid())
  guildId        String
  skuId          String
  entitlementId  String   @unique
  creditsGranted Int      @default(0)
  processedAt    DateTime @default(now()) @db.Timestamptz(6)
}

model PremiumCode {
  id          String    @id @default(cuid())
  code        String    @unique
  type        CodeType
  tier        Tier
  maxUses     Int       @default(1)
  uses        Int       @default(0)
  discountPct Int?
  trialDays   Int?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([code])
}

model Scoreboard {
  id                    String                   @id @default(cuid())
  guildId               String
  name                  String
  metric                String                   @default("WIN_LOSS")
  type                  BoardType                @default(USER)
  channelId             String?
  messageId             String?
  theme                 String                   @default("default")
  liveTitle             String?
  description           String?
  season                Int?
  lastLeaderId          String?
  isArchived            Boolean                  @default(false)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  publicId              String?                  @unique
  repairStatus          String                   @default("OK")
  roleImageUrl          String?
  lastUpdatedAt         DateTime?
  archivedAt            DateTime?
  archivedBy            String?
  archiveNote           String?
  hasCategories         Boolean                  @default(false)
  brandingImageUrl      String?
  friendlyArchiveId     String?                  @unique
  restoredFromArchiveId String?
  guild                 Guild                    @relation(fields: [guildId], references: [id])
  actions               ScoreboardAction[]
  entries               ScoreboardEntry[]
  mergeHistories        ScoreboardMergeHistory[]
  userRoleScores        UserRoleScore[]

  @@index([guildId])
}

model ScoreboardScoreType {
  id             String   @id @default(cuid())
  guildId        String
  scoreboardId   String
  name           String
  normalizedName String
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@unique([scoreboardId, normalizedName])
}

model ScoreboardEntryTypeStats {
  id                String   @id @default(cuid())
  guildId           String
  scoreboardId      String
  scoreboardEntryId String
  scoreTypeId       String
  wins              Int      @default(0)
  losses            Int      @default(0)
  points            Int      @default(0)
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@unique([scoreboardEntryId, scoreTypeId], map: "ScoreboardEntryTypeStats_entryId_typeId_key")
}

model ScoreboardEntry {
  id                   String     @id @default(cuid())
  scoreboardId         String
  targetId             String
  targetType           BoardType
  wins                 Int        @default(0)
  losses               Int        @default(0)
  points               Int        @default(0)
  winStreak            Int        @default(0)
  lossStreak           Int        @default(0)
  updatedAt            DateTime   @updatedAt
  liveChannelId        String?
  liveMessageId        String?
  sourceScoreboardId   String?
  sourceScoreboardName String?
  targetName           String?
  scoreboard           Scoreboard @relation(fields: [scoreboardId], references: [id])

  @@unique([scoreboardId, targetId])
  @@index([scoreboardId])
  @@index([sourceScoreboardId])
}

model ScoreboardAction {
  id           String     @id @default(cuid())
  scoreboardId String
  targetId     String
  action       String
  delta        Int
  reason       String?
  adminId      String
  createdAt    DateTime   @default(now())
  scoreboard   Scoreboard @relation(fields: [scoreboardId], references: [id])

  @@index([scoreboardId])
}

model ScoreboardMergeHistory {
  id                   String     @id @default(cuid())
  guildId              String
  targetScoreboardId   String
  sourceScoreboardId   String
  sourceScoreboardName String
  mergeOption          String
  mergedBy             String
  entriesMerged        Int        @default(0)
  sourceAction         String
  mergedAt             DateTime   @default(now())
  targetScoreboard     Scoreboard @relation(fields: [targetScoreboardId], references: [id])

  @@index([guildId])
  @@index([targetScoreboardId])
  @@index([sourceScoreboardId])
}

model Game {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  isActive  Boolean    @default(true)
  buildings Building[]
  research  Research[]
  resources Resource[]
  units     Unit[]

  @@index([slug])
}

model Unit {
  id          String    @id @default(cuid())
  gameId      String
  name        String
  aliases     String[]
  doctrine    String?
  category    String?
  description String?
  stats       Json?
  iconUrl     String?
  imageUrl    String?
  isActive    Boolean   @default(true)
  isDraft     Boolean   @default(false)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  game        Game      @relation(fields: [gameId], references: [id])

  @@index([gameId])
}

model Building {
  id          String    @id @default(cuid())
  gameId      String
  name        String
  aliases     String[]
  description String?
  stats       Json?
  iconUrl     String?
  isActive    Boolean   @default(true)
  isDraft     Boolean   @default(false)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  game        Game      @relation(fields: [gameId], references: [id])

  @@index([gameId])
}

model Resource {
  id          String   @id @default(cuid())
  gameId      String
  name        String
  aliases     String[]
  description String?
  iconUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  game        Game     @relation(fields: [gameId], references: [id])

  @@index([gameId])
}

model Research {
  id          String    @id @default(cuid())
  gameId      String
  name        String
  aliases     String[]
  description String?
  stats       Json?
  iconUrl     String?
  isActive    Boolean   @default(true)
  isDraft     Boolean   @default(false)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  game        Game      @relation(fields: [gameId], references: [id])

  @@index([gameId])
}

model BattleSignup {
  id           String              @id @default(cuid())
  guildId      String
  channelId    String
  messageId    String?
  threadId     String?
  captainId    String
  game         String
  title        String?
  description  String?
  mode         String?
  scheduledAt  DateTime
  teamSize     Int
  tagOnCreate  String?
  tagOnStart   String?
  status       SignupStatus        @default(OPEN)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  publicId     String?
  cleanupAfter DateTime?
  guild        Guild               @relation(fields: [guildId], references: [id])
  participants SignupParticipant[]

  @@index([guildId])
}

model SignupParticipant {
  id       String            @id @default(cuid())
  signupId String
  userId   String
  status   ParticipantStatus
  joinedAt DateTime          @default(now())
  signup   BattleSignup      @relation(fields: [signupId], references: [id])

  @@unique([signupId, userId])
}

model Event {
  id                    String                 @id @default(cuid())
  guildId               String
  title                 String
  description           String?
  location              String?
  imageUrl              String?
  thumbnailUrl          String?
  channelId             String
  messageId             String?
  scheduledAt           DateTime
  createdBy             String
  tagOnCreate           Boolean                @default(false)
  tagOnStart            Boolean                @default(false)
  status                EventStatus            @default(UPCOMING)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  publicId              String?                @unique
  eventType             String                 @default("EVENT")
  cleanupAfter          DateTime?
  game                  String?
  customTypeName        String?
  timezoneUsed          String?
  reminderBeforeMinutes Int?
  teamSize              Int?
  color                 String?
  tagRoleIds            String[]               @default([])
  eventNumber           Int?                   @unique
  guild                 Guild                  @relation(fields: [guildId], references: [id])
  notificationLogs      EventNotificationLog[]
  reminders             EventReminder[]
  rsvps                 EventRsvp[]

  @@index([guildId])
  @@index([scheduledAt])
  @@index([status])
  @@index([cleanupAfter])
}

model EventRsvp {
  id        String     @id @default(cuid())
  eventId   String
  userId    String
  status    RsvpStatus
  updatedAt DateTime   @updatedAt
  event     Event      @relation(fields: [eventId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
}

/// *
///  * Tracks each notification type that has been sent for an event.
///  * Unique constraint on (eventId, notificationType) prevents double-sends
///  * even if the bot restarts or the job fires twice.
model EventNotificationLog {
  id               String   @id @default(cuid())
  eventId          String
  guildId          String
  notificationType String
  channelId        String?
  messageId        String?
  roleId           String?
  sentAt           DateTime @default(now())
  event            Event    @relation(fields: [eventId], references: [id])

  @@unique([eventId, notificationType])
  @@index([eventId])
}

/// *
///  * Per-user personal reminders set via the "Remind Me" button.
model EventReminder {
  id        String    @id @default(cuid())
  eventId   String
  userId    String
  remindAt  DateTime
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  event     Event     @relation(fields: [eventId], references: [id])

  @@unique([eventId, userId])
  @@index([remindAt])
  @@index([eventId])
}

model Suggestion {
  id         String           @id @default(cuid())
  guildId    String
  authorId   String
  content    String
  imageUrl   String?
  status     SuggestionStatus @default(OPEN)
  channelId  String
  messageId  String?
  expiresAt  DateTime?
  createdAt  DateTime         @default(now())
  publicId   String?          @unique
  title      String           @default("")
  updatedAt  DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  approvedBy String?
  approvedAt DateTime?        @db.Timestamptz(6)
  deniedBy   String?
  deniedAt   DateTime?        @db.Timestamptz(6)
  adminNote  String?
  showVoters Boolean          @default(false)
  category   String           @default("GENERAL")
  guild      Guild            @relation(fields: [guildId], references: [id])
  votes      SuggestionVote[]

  @@index([guildId])
}

model SuggestionVote {
  id           String     @id @default(cuid())
  suggestionId String
  userId       String
  type         VoteType
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id])

  @@unique([suggestionId, userId])
}

model PlayerProfile {
  id                      String             @id @default(cuid())
  discordId               String             @unique
  gameUsername            String?
  game                    String?            @default("supremacy-ww3")
  currentAlliance         String?
  currentAllianceTag      String?
  currentAllianceJoinedAt DateTime?
  inGameRank              String?
  level                   Int?
  xpCurrent               Int?
  xpMax                   Int?
  kdRatio                 Float?
  unitsKilled             Int?
  unitsLost               Int?
  provincesTaken          Int?
  provincesLost           Int?
  gamesJoined             Int?
  soloVictories           Int?
  coalitionVictories      Int?
  overallScore            Int?
  overallRank             Int?
  economicRank            Int?
  militaryRank            Int?
  memberSince             String?
  lastOnline              String?
  playedOnPC              Int?
  playedOnMobile          Int?
  role                    String?
  playstyle               String?
  discoreElo              Int                @default(1000)
  winRate                 Float?
  performanceScore        Int?
  combatStyle             String?
  isPublic                Boolean            @default(true)
  profileImageUrl         String?
  screenshotUrls          String[]
  lastUpdateAt            DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  allianceHistory         AllianceHistory[]
  updateLogs              ProfileUpdateLog[]

  @@index([discordId])
}

model AllianceHistory {
  id           String        @id @default(cuid())
  playerId     String
  allianceName String
  allianceTag  String?
  game         String
  joinedAt     DateTime
  leftAt       DateTime?
  player       PlayerProfile @relation(fields: [playerId], references: [id])

  @@index([playerId])
}

model ProfileUpdateLog {
  id        String        @id @default(cuid())
  playerId  String
  updatedAt DateTime      @default(now())
  player    PlayerProfile @relation(fields: [playerId], references: [id])

  @@index([playerId])
}

model AllianceProfile {
  id                                                String                @id @default(cuid())
  name                                              String
  tag                                               String
  game                                              String
  logoUrl                                           String?
  bannerUrl                                         String?
  description                                       String?
  discordInvite                                     String?
  country                                           String?
  tags                                              String[]
  ownerId                                           String?
  managerRoleId                                     String?
  officialId                                        String?
  officialRank                                      Int?
  officialElo                                       Int?
  officialWins                                      Int?
  officialLosses                                    Int?
  officialMembers                                   Int?
  officialMaxMembers                                Int?
  founded                                           String?
  discoreRank                                       Int?
  discoreElo                                        Int                   @default(1000)
  discoreWins                                       Int                   @default(0)
  discoreLosses                                     Int                   @default(0)
  winRate                                           Float?
  seasonRecord                                      String?
  isPublic                                          Boolean               @default(true)
  screenshotUrls                                    String[]
  lastUpdateAt                                      DateTime?
  createdAt                                         DateTime              @default(now())
  updatedAt                                         DateTime              @updatedAt
  recentMatches                                     AllianceRecentMatch[]
  updateLogs                                        AllianceUpdateLog[]

  @@unique([tag, game])
  @@index([game])
}

model AllianceRecentMatch {
  id           String          @id @default(cuid())
  allianceId   String
  opponentName String
  opponentTag  String?
  opponentLogo String?
  result       MatchResult
  occurredAt   DateTime        @default(now())
  alliance     AllianceProfile @relation(fields: [allianceId], references: [id])

  @@index([allianceId])
}

model AllianceUpdateLog {
  id         String          @id @default(cuid())
  allianceId String
  updatedBy  String
  updatedAt  DateTime        @default(now())
  alliance   AllianceProfile @relation(fields: [allianceId], references: [id])

  @@index([allianceId])
}

model LeaderboardChannel {
  id        String          @id @default(cuid())
  guildId   String
  type      LeaderboardType
  channelId String
  messageId String?
  enabled   Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([guildId, type])
  @@index([guildId])
}

model LeaderboardSettings {
  id             String    @id @default(cuid())
  guildId        String    @unique
  scheduleHour   Int       @default(9)
  scheduleMinute Int       @default(0)
  frequencyHours Int       @default(24)
  lastPostedAt   DateTime?
  enabled        Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AiCredits {
  id        String   @id @default(cuid())
  guildId   String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model AiUsageLog {
  id          String   @id @default(cuid())
  guildId     String
  userId      String
  requestType String
  cost        Int
  createdAt   DateTime @default(now())

  @@index([guildId])
}

model AuditLog {
  id        String   @id @default(cuid())
  guildId   String
  action    String
  actorId   String
  targetId  String?
  meta      Json?
  createdAt DateTime @default(now())
  guild     Guild    @relation(fields: [guildId], references: [id])

  @@index([guildId])
}

model MatchWatcher {
  id         String   @id @default(cuid())
  guildId    String
  channelId  String
  createdBy  String
  game       String
  mode       String?
  maxPlayers Int?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([guildId])
  @@index([game, isActive])
}

model BattleReminder {
  id        String   @id @default(cuid())
  signupId  String
  userId    String
  remindAt  DateTime
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([signupId, userId])
  @@index([remindAt, sent])
}

model UserActivity {
  id                  String    @id @default(cuid())
  guildId             String
  userId              String
  lastMessageAt       DateTime?
  lastReactionAt      DateTime?
  lastInteractionAt   DateTime?
  lastActiveAt        DateTime?
  activeDayStreak     Int       @default(0)
  lastActiveDate      DateTime?
  mostActiveChannelId String?
  mostUsedReaction    String?
  updatedAt           DateTime  @updatedAt
  guild               Guild     @relation(fields: [guildId], references: [id])

  @@unique([guildId, userId])
  @@index([guildId, userId])
  @@index([lastActiveAt])
}

model ModerationCase {
  id              String            @id @default(cuid())
  publicId        String            @unique
  guildId         String
  userId          String
  moderatorId     String
  actionType      ModActionType
  reason          String
  durationSeconds Int?
  expiresAt       DateTime?
  status          CaseStatus        @default(ACTIVE)
  appealStatus    AppealStatus?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  revokedAt       DateTime?
  revokedBy       String?
  staffNote       String?
  appeals         Appeal[]
  guild           Guild             @relation(fields: [guildId], references: [id])
  roleSnapshot    UserRoleSnapshot?

  @@index([guildId])
  @@index([userId])
  @@index([publicId])
  @@index([status])
  @@index([expiresAt])
  @@index([appealStatus])
}

model Appeal {
  id         String         @id @default(cuid())
  publicId   String         @unique
  caseId     String
  guildId    String
  userId     String
  appealText String
  status     AppealStatus   @default(OPEN)
  channelId  String?
  createdAt  DateTime       @default(now())
  closedAt   DateTime?
  closedBy   String?
  outcome    String?
  staffNotes String?
  case       ModerationCase @relation(fields: [caseId], references: [id])
  guild      Guild          @relation(fields: [guildId], references: [id])

  @@index([caseId])
  @@index([guildId])
  @@index([publicId])
  @@index([status])
}

model UserRoleSnapshot {
  id           String         @id @default(cuid())
  guildId      String
  userId       String
  caseId       String         @unique
  roleIds      String[]
  createdAt    DateTime       @default(now())
  cleanupAfter DateTime?
  case         ModerationCase @relation(fields: [caseId], references: [id])

  @@index([caseId])
  @@index([cleanupAfter])
}

model AutoModRule {
  id                String        @id @default(cuid())
  guildId           String
  name              String?
  phrase            String
  matchType         MatchType     @default(CONTAINS)
  action            AutoModAction @default(REVIEW)
  severity          String        @default("MEDIUM")
  enabled           Boolean       @default(true)
  exemptRoleIds     Json?
  ignoredChannelIds Json?
  reviewChannelId   String?
  timeoutSeconds    Int?
  deleteMessage     Boolean       @default(false)
  userMessage       String?       @db.Text
  appealEnabled     Boolean       @default(false)
  triggerCount      Int           @default(0)
  lastTriggeredAt   DateTime?
  createdBy         String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  cases             AutoModCase[]
  guild             Guild         @relation(fields: [guildId], references: [id])

  @@index([guildId])
  @@index([enabled])
}

model AutoModCase {
  id               String        @id @default(cuid())
  publicId         String        @unique
  guildId          String
  userId           String
  channelId        String
  messageId        String?
  ruleId           String
  matchedText      String?
  messageExcerpt   String
  actionTaken      AutoModAction
  status           ReviewStatus  @default(PENDING)
  reviewMessageId  String?
  resolutionAction String?
  moderationCaseId String?
  cleanupAfter     DateTime?
  createdAt        DateTime      @default(now())
  reviewedAt       DateTime?
  reviewedBy       String?
  guild            Guild         @relation(fields: [guildId], references: [id])
  rule             AutoModRule   @relation(fields: [ruleId], references: [id])

  @@index([guildId])
  @@index([status])
  @@index([cleanupAfter])
}

model AiUsage {
  id           String   @id @default(cuid())
  guildId      String
  userId       String
  month        String
  creditsUsed  Int      @default(0)
  requestCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([guildId, month])
  @@index([guildId, month])
}

model UserRoleScore {
  id           String     @id @default(cuid())
  guildId      String
  userId       String
  roleId       String
  scoreboardId String
  wins         Int        @default(0)
  losses       Int        @default(0)
  points       Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  scoreboard   Scoreboard @relation(fields: [scoreboardId], references: [id])

  @@unique([scoreboardId, roleId, userId])
  @@index([guildId, userId])
  @@index([roleId])
}

model GameDataSource {
  id         String     @id @default(cuid())
  game       String
  gameKey    String     @unique
  sourceName String
  apiUrl     String
  targetPage String
  sourceType SourceType @default(MEDIAWIKI_API)
  enabled    Boolean    @default(true)
  lastSyncAt DateTime?
  lastError  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model GameUnit {
  id                 String            @id @default(cuid())
  game               String
  gameKey            String
  name               String
  slug               String
  category           String?
  description        String?
  sourceUrl          String?
  sourceName         String?
  sourcePage         String?
  sourceLastSyncedAt DateTime?
  verified           Boolean           @default(false)
  manuallyEdited     Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  features           GameUnitFeature[]
  variants           GameUnitVariant[]

  @@unique([gameKey, slug])
  @@index([game, category])
  @@index([name])
}

model GameUnitVariant {
  id                    String                @id @default(cuid())
  unitId                String
  doctrine              String?
  generation            Int?
  tier                  Int?
  level                 Int?
  description           String?
  hitPoints             Float?
  speed                 Float?
  range                 Float?
  sightRange            Float?
  radarRange            Float?
  stealthDetectionRange Float?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  costs                 GameUnitCost[]
  terrainStats          GameUnitTerrainStat[]
  upkeep                GameUnitUpkeep[]
  unit                  GameUnit              @relation(fields: [unitId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([unitId])
}

model GameUnitFeature {
  id          String   @id @default(cuid())
  unitId      String
  variantId   String?
  name        String
  value       String
  description String?
  unit        GameUnit @relation(fields: [unitId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([unitId])
}

model GameUnitCost {
  id            String          @id @default(cuid())
  variantId     String
  supplies      Int?
  components    Int?
  manpower      Int?
  electronics   Int?
  fuel          Int?
  cash          Int?
  rareMaterials Int?
  timeSeconds   Int?
  rawTimeText   String?
  variant       GameUnitVariant @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([variantId])
}

model GameUnitUpkeep {
  id            String          @id @default(cuid())
  variantId     String
  supplies      Int?
  components    Int?
  manpower      Int?
  electronics   Int?
  fuel          Int?
  cash          Int?
  rareMaterials Int?
  variant       GameUnitVariant @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([variantId])
}

model GameUnitTerrainStat {
  id              String          @id @default(cuid())
  variantId       String
  terrain         String
  hitPoints       Float?
  speed           Float?
  attackModifier  Float?
  defenseModifier Float?
  sightRange      Float?
  variant         GameUnitVariant @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([variantId])
}

model GameUnitImportDraft {
  id         String       @id @default(cuid())
  game       String
  gameKey    String
  sourceUrl  String?
  sourceName String?
  sourcePage String?
  rawExtract String?
  parsedJson Json?
  confidence String       @default("LOW")
  warnings   String[]     @default([])
  status     ImportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([gameKey, status])
  @@index([status])
}

model ModerationCaseTranscript {
  id                String    @id @default(cuid())
  guildId           String
  caseId            String?
  appealId          String?
  caseNumber        String?
  appealNumber      String?
  ticketChannelId   String?
  ticketChannelName String?
  userId            String?
  handledById       String?
  outcome           String?
  openedAt          DateTime? @db.Timestamptz(6)
  closedAt          DateTime? @db.Timestamptz(6)
  messageCount      Int       @default(0)
  transcriptJson    String?
  transcriptText    String?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)

  @@index([caseId])
  @@index([appealNumber])
  @@index([guildId])
  @@index([createdAt])
}

model BotCommandUsage {
  id          String   @id @default(cuid())
  guildId     String?
  userId      String
  commandName String
  subcommand  String?
  success     Boolean  @default(true)
  durationMs  Int?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([createdAt])
  @@index([guildId])
  @@index([commandName])
}

model BotAiUsage {
  id          String   @id @default(cuid())
  guildId     String?
  userId      String?
  success     Boolean  @default(true)
  creditsUsed Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  requestType String?

  @@index([createdAt])
  @@index([guildId])
}

model BotGuildInstallEvent {
  id          String   @id @default(cuid())
  guildId     String
  guildName   String
  memberCount Int      @default(0)
  ownerId     String?
  eventType   String
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([guildId])
  @@index([eventType, createdAt])
}

model BotHourlyStatusReport {
  id          String   @id @default(cuid())
  channelId   String
  reportHour  String
  sentAt      DateTime @default(now()) @db.Timestamptz(6)
  status      String   @default("success")
  payloadJson String?
}

model SafeVaultRound {
  id                   String             @id @default(cuid())
  code                 String
  status               String             @default("ACTIVE")
  generatedAt          DateTime           @default(now()) @db.Timestamptz(6)
  expiresAt            DateTime?          @db.Timestamptz(6)
  crackedAt            DateTime?          @db.Timestamptz(6)
  crackedByUserId      String?
  crackedByUserTag     String?
  crackedByDisplayName String?
  crackedInGuildId     String?
  crackedInGuildName   String?
  selectedPrize        String?
  prizeStatus          String?
  createdAt            DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @db.Timestamptz(6)
  attempts             SafeVaultAttempt[]

  @@index([status])
  @@index([generatedAt])
  @@index([crackedByUserId])
}

model SafeVaultAttempt {
  id          String         @id @default(cuid())
  roundId     String
  userId      String
  userTag     String?
  displayName String?
  guildId     String
  guildName   String?
  guessedCode String
  correct     Boolean        @default(false)
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)
  round       SafeVaultRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId])
  @@index([userId])
  @@index([guildId])
  @@index([createdAt])
}

model SafeVaultDailyLimit {
  id           String   @id @default(cuid())
  userId       String
  dateKey      String
  attemptsUsed Int      @default(0)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  @@unique([userId, dateKey])
  @@index([dateKey])
}

model AutoPost {
  id               String        @id @default(cuid())
  guildId          String
  name             String
  enabled          Boolean       @default(true)
  status           AutoPostStatus @default(ACTIVE)
  triggerType      TriggerType
  channelId        String
  messageMode      MessageMode   @default(PLAIN)
  content          String?       @db.Text
  embedTitle       String?
  embedDescription String?       @db.Text
  embedColor       String?
  embedFooter      String?
  embedImageUrl    String?
  triggerConfig    Json?
  scheduleConfig   Json?
  timezone         String        @default("UTC")
  nextRunAt        DateTime?
  lastRunAt        DateTime?
  cooldownSeconds  Int           @default(300)
  lastTriggeredAt  DateTime?
  failureCount     Int           @default(0)
  pausedReason     String?
  createdById      String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([guildId])
  @@index([guildId, status])
  @@index([guildId, enabled])
  @@index([triggerType])
  @@index([nextRunAt])
}

model TrackedRole {
  guildId   String
  roleId    String
  purpose   String   @default("SCOREBOARD")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@id([guildId, roleId])
}

model TrackedRoleMember {
  guildId   String
  roleId    String
  userId    String
  joinedAt  DateTime @default(now())
  updatedAt DateTime @default(now())

  @@id([guildId, roleId, userId])
  @@index([guildId, roleId], map: "TrackedRoleMember_guild_role_idx")
  @@index([guildId, userId], map: "TrackedRoleMember_guild_user_idx")
}

model GuildXpConfig {
  id                          String    @id @default(cuid())
  guildId                     String    @unique
  enabled                     Boolean   @default(true)
  levelUpChannelId            String?
  weeklyLeaderboardChannelId  String?
  messageXpEnabled            Boolean   @default(true)
  reactionXpEnabled           Boolean   @default(true)
  minMessageXp                Int       @default(15)
  maxMessageXp                Int       @default(40)
  messageCooldownSeconds      Int       @default(60)
  minReactionXp               Int       @default(5)
  maxReactionXp               Int       @default(10)
  reactionCooldownSeconds     Int       @default(300)
  announceLevelUps            Boolean   @default(true)
  weeklyTop10Enabled          Boolean   @default(false)
  profileColor                String?
  lastWeeklyLeaderboardPostAt DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@index([guildId])
}

model UserXp {
  id                String    @id @default(cuid())
  guildId           String
  userId            String
  totalXp           Int       @default(0)
  level             Int       @default(1)
  messagesCounted   Int       @default(0)
  reactionsCounted  Int       @default(0)
  lastMessageXpAt   DateTime?
  lastReactionXpAt  DateTime?
  userTag           String?
  displayName       String?
  avatarUrl         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([guildId, userId])
  @@index([guildId, totalXp])
  @@index([guildId, level])
  @@index([guildId, userId])
  @@index([guildId, messagesCounted])
  @@index([guildId, reactionsCounted])
}

model UserXpEvent {
  id        String    @id @default(cuid())
  guildId   String
  userId    String
  source    String
  amount    Int
  createdAt DateTime  @default(now()) @db.Timestamptz(6)

  @@index([guildId, userId])
  @@index([guildId, createdAt])
  @@index([guildId, source])
}

