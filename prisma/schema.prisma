generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── GUILDS ──────────────────────────────────────────────

model Guild {
  id                String    @id              // Discord guild ID
  defaultGame       String?
  timezone          String    @default("UTC")
  allianceName      String?
  allianceCode      String?   @unique         // 1-6 chars A-Z0-9 for AvA matching
  allianceLogo      String?
  themeColor        String    @default("#1a7a9e")
  scoreboardChan    String?
  logChannelId      String?                   // Replaces adminLogChan
  adminLogChan      String?                   // DEPRECATED - use logChannelId
  premiumNoticeChan String?
  battleSignupChan        String?

  // Moderation / Appeal Channels
  moderationLogChannelId String?
  appealChannelId        String?
  appealCategoryId       String?
  eventChannelId         String?
  suggestionChannelId    String?
  supportChannelId       String?
  adminReportsChannelId  String?

  language                String    @default("en")
  customFooter            String?
  scoreboardManagerRoleId String?
  disAdminRoleId          String?
  publicSuggestionVoters  Boolean   @default(false)
  
  
  // Required Roles
  discoreManagerRoleId    String?
  discoreAppealRoleId     String?
  discoreMutedRoleId      String?
  
  // Onboarding
  onboardingSentAt       DateTime?
  onboardingCompletedAt  DateTime?
  onboardingSkippedAt    DateTime?
  onboardingChannelId    String?

  // Discore Official
  announcementChannelId  String?

  // Maintenance
  maintainRolesAndChannels Boolean  @default(true)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  premium           GuildPremium?
  scoreboards       Scoreboard[]
  events            Event[]
  battleSignups     BattleSignup[]
  suggestions       Suggestion[]
  auditLogs         AuditLog[]
  moderationCases   ModerationCase[]
  appeals           Appeal[]
  autoModRules      AutoModRule[]
  autoModCases      AutoModCase[]
  userActivities    UserActivity[]

  @@index([id])
  @@index([allianceCode])
}

// ── PREMIUM ──────────────────────────────────────────────

model GuildPremium {
  id            String    @id @default(cuid())
  guildId       String    @unique
  guild         Guild     @relation(fields: [guildId], references: [id])
  tier          Tier      @default(FREE)
  method        PremiumMethod
  stripeSubId   String?
  code          String?
  expiresAt     DateTime?
  grantedBy     String?   // Discord user ID of bot owner who granted
  entitlementId String?   // Discord entitlement ID
  // Purchase tracking
  purchasedAt       DateTime?  // When premium was first purchased
  lastRenewalAt     DateTime?  // When premium was last renewed
  renewalCount      Int        @default(0)
  graceNotifiedAt   DateTime?  // When grace period warning was sent
  // AI credit tracking
  monthlyAiAllowance    Int       @default(0)
  monthlyAiUsed         Int       @default(0)
  monthlyAiPeriodStart  DateTime?
  monthlyAiPeriodEnd    DateTime?
  extraAiCredits        Int       @default(0)
  // AI limits
  serverDailyAiLimit    Int       @default(0)
  perUserDailyAiLimit   Int       @default(0)
  cooldownSeconds       Int       @default(0)
  aiEnabled             Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([guildId])
  @@index([expiresAt])
}

model ProcessedEntitlement {
  id              String    @id @default(cuid())
  guildId         String
  skuId           String
  entitlementId   String    @unique
  creditsGranted  Int       @default(0)
  processedAt     DateTime  @default(now())
}

model PremiumCode {
  id          String    @id @default(cuid())
  code        String    @unique
  type        CodeType
  tier        Tier
  maxUses     Int       @default(1)
  uses        Int       @default(0)
  discountPct Int?      // for discount codes
  trialDays   Int?      // for trial codes
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([code])
}

enum Tier {
  FREE
  PRO
  ELITE
  LIFETIME
}

enum PremiumMethod {
  STRIPE
  CODE
  MANUAL
}

enum CodeType {
  LIFETIME
  DISCOUNT
  TRIAL
}

// ── SCOREBOARDS ──────────────────────────────────────────

model Scoreboard {
  id            String    @id @default(cuid())
  publicId      String?   @unique              // short human-readable ID
  guildId       String
  guild         Guild     @relation(fields: [guildId], references: [id])
  name          String
  metric        String    @default("WIN_LOSS")  // WIN_LOSS | POINTS
  type          BoardType @default(USER)
  channelId     String?                        // nullable — not required for non-live boards
  messageId     String?                        // for live editing
  theme         String    @default("default")  // hex color like #FF5733 or preset name
  liveTitle     String?
  description   String?
  season        Int?
  lastLeaderId  String?                        // targetId of current #1 for leader-change detection
  roleImageUrl  String?                        // team/role avatar URL
  repairStatus  String    @default("OK")       // OK | NEEDS_REPAIR | REPAIRING
  lastUpdatedAt DateTime?                      // when last score was changed
  isArchived    Boolean   @default(false)
  archivedAt    DateTime?
  archivedBy    String?                        // Discord user ID
  archiveNote   String?
  hasCategories Boolean   @default(false)      // whether this board supports category views
  brandingImageUrl String?                     // per-scoreboard image set via /server branding
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  entries       ScoreboardEntry[]
  actions       ScoreboardAction[]
  userRoleScores UserRoleScore[]
  mergeHistories ScoreboardMergeHistory[]

  @@index([guildId])

  scoreTypes       ScoreboardScoreType[]
  entryTypeStats   ScoreboardEntryTypeStats[]
}

model ScoreboardScoreType {
  id              String    @id @default(cuid())
  guildId         String
  scoreboardId    String
  scoreboard      Scoreboard @relation(fields: [scoreboardId], references: [id])
  name            String
  normalizedName  String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  entryStats      ScoreboardEntryTypeStats[]

  @@unique([scoreboardId, normalizedName])
  @@index([scoreboardId])
}

model ScoreboardEntryTypeStats {
  id                String    @id @default(cuid())
  guildId           String
  scoreboardId      String
  scoreboard        Scoreboard @relation(fields: [scoreboardId], references: [id])
  scoreboardEntryId String
  scoreTypeId       String
  scoreType         ScoreboardScoreType @relation(fields: [scoreTypeId], references: [id])
  wins              Int       @default(0)
  losses            Int       @default(0)
  points            Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([scoreboardEntryId, scoreTypeId])
  @@index([scoreboardEntryId])
  @@index([scoreTypeId])
}

model ScoreboardEntry {
  id                   String    @id @default(cuid())
  scoreboardId         String
  scoreboard           Scoreboard @relation(fields: [scoreboardId], references: [id])
  targetId             String    // Discord user ID, role ID, or custom key
  targetType           BoardType
  targetName           String?   // display name for CUSTOM targets, or fallback for USER/ROLE
  wins                 Int       @default(0)
  losses               Int       @default(0)
  points               Int       @default(0)
  winStreak            Int       @default(0)
  lossStreak           Int       @default(0)
  liveChannelId        String?   // channel to post per-entry live score embed
  liveMessageId        String?   // message to edit for per-entry live score embed
  sourceScoreboardId   String?   // original source board ID when merged into a totals board
  sourceScoreboardName String?   // original source board name when merged into a totals board
  updatedAt            DateTime  @updatedAt

  @@unique([scoreboardId, targetId])
  @@index([scoreboardId])
  @@index([sourceScoreboardId])
}

model ScoreboardAction {
  id            String    @id @default(cuid())
  scoreboardId  String
  scoreboard    Scoreboard @relation(fields: [scoreboardId], references: [id])
  targetId      String
  action        String    // "WIN", "LOSS", "POINT", "RESET", "MERGE", "CREATE", "EDIT", "DELETE_ENTRY"
  delta         Int
  reason        String?
  adminId       String
  createdAt     DateTime  @default(now())

  @@index([scoreboardId])
}

model ScoreboardMergeHistory {
  id                   String    @id @default(cuid())
  guildId              String
  targetScoreboardId   String
  targetScoreboard     Scoreboard @relation(fields: [targetScoreboardId], references: [id])
  sourceScoreboardId   String
  sourceScoreboardName String
  mergeOption          String    // DELETE | CLEAR_KEEP_LIVE | KEEP_LIVE_KEEP_SCORES | ARCHIVE
  mergedBy             String    // Discord user ID
  entriesMerged        Int       @default(0)
  sourceAction         String    // DELETED | CLEARED_KEEP_LIVE | KEPT_LIVE | ARCHIVED
  mergedAt             DateTime  @default(now())

  @@index([guildId])
  @@index([targetScoreboardId])
  @@index([sourceScoreboardId])
}

enum BoardType {
  USER
  ROLE
  CUSTOM
}

// ── GAME DATA ─────────────────────────────────────────────

model Game {
  id          String  @id @default(cuid())
  slug        String  @unique  // "supremacy-ww3", "call-of-war"
  name        String
  isActive    Boolean @default(true)

  units       Unit[]
  buildings   Building[]
  resources   Resource[]
  research    Research[]

  @@index([slug])
}

model Unit {
  id          String  @id @default(cuid())
  gameId      String
  game        Game    @relation(fields: [gameId], references: [id])
  name        String
  aliases     String[]
  doctrine    String?
  category    String?
  description String?
  stats       Json?
  iconUrl     String?
  imageUrl    String?
  isActive    Boolean @default(true)
  isDraft     Boolean @default(false)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([gameId])
}

model Building {
  id          String  @id @default(cuid())
  gameId      String
  game        Game    @relation(fields: [gameId], references: [id])
  name        String
  aliases     String[]
  description String?
  stats       Json?
  iconUrl     String?
  isActive    Boolean @default(true)
  isDraft     Boolean @default(false)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([gameId])
}

model Resource {
  id          String  @id @default(cuid())
  gameId      String
  game        Game    @relation(fields: [gameId], references: [id])
  name        String
  aliases     String[]
  description String?
  iconUrl     String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())

  @@index([gameId])
}

model Research {
  id          String  @id @default(cuid())
  gameId      String
  game        Game    @relation(fields: [gameId], references: [id])
  name        String
  aliases     String[]
  description String?
  stats       Json?
  iconUrl     String?
  isActive    Boolean @default(true)
  isDraft     Boolean @default(false)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([gameId])
}

// ── BATTLE SIGNUP ─────────────────────────────────────────

model BattleSignup {
  id            String    @id @default(cuid())
  publicId      String?
  guildId       String
  guild         Guild     @relation(fields: [guildId], references: [id])
  channelId     String
  messageId     String?
  threadId      String?
  captainId     String
  game          String
  title         String?
  description   String?
  mode          String?
  scheduledAt   DateTime
  teamSize      Int
  tagOnCreate   String?   // role ID to ping when signup is created
  tagOnStart    String?   // role ID to ping when battle starts
  status        SignupStatus @default(OPEN)
  cleanupAfter  DateTime?                      // set when completed/cancelled
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  participants  SignupParticipant[]

  @@index([guildId])
}

model SignupParticipant {
  id          String    @id @default(cuid())
  signupId    String
  signup      BattleSignup @relation(fields: [signupId], references: [id])
  userId      String
  status      ParticipantStatus
  joinedAt    DateTime  @default(now())

  @@unique([signupId, userId])
}

enum SignupStatus {
  OPEN
  LOCKED
  STARTED
  CANCELLED
  COMPLETED
}

enum ParticipantStatus {
  ACCEPTED
  RESERVE
  DECLINED
}

// ── EVENTS ───────────────────────────────────────────────

model Event {
  id                    String      @id @default(cuid())
  publicId              String?     @unique
  guildId               String
  guild                 Guild       @relation(fields: [guildId], references: [id])
  title                 String
  description           String?
  location              String?
  game                  String?     // game name (optional)
  customTypeName        String?     // label used when eventType = CUSTOM
  imageUrl              String?     // banner — full-width at bottom of embed
  thumbnailUrl          String?     // small thumbnail — top-right of embed
  eventType             String      @default("EVENT")  // EVENT|BATTLE|TEAM|COMMUNITY|TRAINING|GAME_START|CUSTOM
  teamSize              Int?        // for battle/signup events: slots per side
  color                 String?     // custom hex color overrides default (e.g. "#e74c3c")
  channelId             String
  messageId             String?
  scheduledAt           DateTime
  timezoneUsed          String?     // detected or explicit timezone
  reminderBeforeMinutes Int?        // minutes before start for global channel reminder
  createdBy             String
  tagRoleIds            String[]    @default([])  // role IDs to ping (up to 5)
  tagOnCreate           Boolean     @default(false)   // ping on creation
  tagOnStart            Boolean     @default(false)   // ping when event goes LIVE
  eventNumber           Int?        @unique          // sequential display ID
  status                EventStatus @default(UPCOMING)
  cleanupAfter          DateTime?   // cleanup job deletes DB row after this date
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  rsvps                 EventRsvp[]
  notificationLogs      EventNotificationLog[]
  reminders             EventReminder[]

  @@index([guildId])
  @@index([scheduledAt])
  @@index([status])
  @@index([cleanupAfter])
}

model EventRsvp {
  id        String     @id @default(cuid())
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id])
  userId    String
  status    RsvpStatus
  updatedAt DateTime   @updatedAt
  @@unique([eventId, userId])
  @@index([eventId])
}

/**
 * Tracks each notification type that has been sent for an event.
 * Unique constraint on (eventId, notificationType) prevents double-sends
 * even if the bot restarts or the job fires twice.
 */
model EventNotificationLog {
  id               String   @id @default(cuid())
  eventId          String
  event            Event    @relation(fields: [eventId], references: [id])
  guildId          String
  notificationType String   // CREATE | REMINDER | START
  channelId        String?
  messageId        String?
  roleId           String?
  sentAt           DateTime @default(now())

  @@unique([eventId, notificationType])
  @@index([eventId])
}

/**
 * Per-user personal reminders set via the "Remind Me" button.
 */
model EventReminder {
  id        String    @id @default(cuid())
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id])
  userId    String
  remindAt  DateTime
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([eventId, userId])
  @@index([remindAt])
  @@index([eventId])
}

enum EventStatus {
  UPCOMING
  LIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

enum RsvpStatus {
  GOING
  MAYBE
  NOT_GOING
}

// ── SUGGESTIONS ───────────────────────────────────────────

model Suggestion {
  id          String    @id @default(cuid())
  publicId    String?   @unique
  guildId     String
  guild       Guild     @relation(fields: [guildId], references: [id])
  authorId    String
  title       String    @default("")
  content     String
  imageUrl    String?
  status      SuggestionStatus @default(PENDING)
  category    String    @default("GENERAL")
  showVoters  Boolean   @default(false)
  channelId   String
  messageId   String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  approvedBy  String?
  approvedAt  DateTime?
  deniedBy    String?
  deniedAt    DateTime?
  adminNote   String?

  votes       SuggestionVote[]

  @@index([guildId])
  @@index([publicId])
}

model SuggestionVote {
  id            String    @id @default(cuid())
  suggestionId  String
  suggestion    Suggestion @relation(fields: [suggestionId], references: [id])
  userId        String
  type          VoteType
  @@unique([suggestionId, userId])
}

enum SuggestionStatus {
  PENDING
  APPROVED
  DENIED
  DELETED
  EXPIRED
}

enum VoteType {
  UP
  DOWN
}

// ── PLAYERS & ALLIANCES ───────────────────────────────────

model PlayerProfile {
  id                      String    @id @default(cuid())
  discordId               String    @unique
  gameUsername            String?
  game                    String?   @default("supremacy-ww3")
  // Alliance
  currentAlliance         String?
  currentAllianceTag      String?
  currentAllianceJoinedAt DateTime?
  // In-game stats
  inGameRank              String?   // "Staff Sergeant", "Commander"
  level                   Int?
  xpCurrent               Int?
  xpMax                   Int?
  kdRatio                 Float?
  unitsKilled             Int?
  unitsLost               Int?
  provincesTaken          Int?
  provincesLost           Int?
  gamesJoined             Int?
  soloVictories           Int?
  coalitionVictories      Int?
  overallScore            Int?
  overallRank             Int?
  economicRank            Int?
  militaryRank            Int?
  memberSince             String?
  lastOnline              String?
  playedOnPC              Int?      // percentage 0-100
  playedOnMobile          Int?      // percentage 0-100
  // Discore verified stats
  role                    String?   // "Shot Caller", "Strategist" etc.
  playstyle               String?
  discoreElo              Int       @default(1000)
  winRate                 Float?
  performanceScore        Int?      // 0-100
  combatStyle             String?   // short description
  // Profile settings
  isPublic                Boolean   @default(true)
  profileImageUrl         String?
  screenshotUrls          String[]
  lastUpdateAt            DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  allianceHistory         AllianceHistory[]
  updateLogs              ProfileUpdateLog[]

  @@index([discordId])
}

model AllianceHistory {
  id            String    @id @default(cuid())
  playerId      String
  player        PlayerProfile @relation(fields: [playerId], references: [id])
  allianceName  String
  allianceTag   String?
  game          String
  joinedAt      DateTime
  leftAt        DateTime?

  @@index([playerId])
}

model ProfileUpdateLog {
  id          String    @id @default(cuid())
  playerId    String
  player      PlayerProfile @relation(fields: [playerId], references: [id])
  updatedAt   DateTime  @default(now())

  @@index([playerId])
}

model AllianceProfile {
  id                  String    @id @default(cuid())
  name                String
  tag                 String
  game                String
  logoUrl             String?
  bannerUrl           String?
  description         String?
  discordInvite       String?
  country             String?
  tags                String[]  // ["COMPETITIVE", "ACTIVE", "TEAMWORK"]
  ownerId             String?   // Discord user ID who registered
  managerRoleId       String?   // Discord role that can manage
  // Official in-game stats
  officialId          String?
  officialRank        Int?
  officialElo         Int?
  officialWins        Int?
  officialLosses      Int?
  officialMembers     Int?
  officialMaxMembers  Int?
  founded             String?   // date string e.g. "5/31/24"
  // Discore verified stats
  discoreRank         Int?
  discoreElo          Int       @default(1000)
  discoreWins         Int       @default(0)
  discoreLosses       Int       @default(0)
  winRate             Float?
  seasonRecord        String?   // "89W – 31L"
  // Profile settings
  isPublic            Boolean   @default(true)
  screenshotUrls      String[]
  lastUpdateAt        DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  recentMatches       AllianceRecentMatch[]
  updateLogs          AllianceUpdateLog[]

  @@unique([tag, game])
  @@index([game])
}

model AllianceRecentMatch {
  id            String      @id @default(cuid())
  allianceId    String
  alliance      AllianceProfile @relation(fields: [allianceId], references: [id])
  opponentName  String
  opponentTag   String?
  opponentLogo  String?
  result        MatchResult
  occurredAt    DateTime    @default(now())

  @@index([allianceId])
}

model AllianceUpdateLog {
  id          String    @id @default(cuid())
  allianceId  String
  alliance    AllianceProfile @relation(fields: [allianceId], references: [id])
  updatedBy   String    // Discord user ID
  updatedAt   DateTime  @default(now())

  @@index([allianceId])
}

enum MatchResult {
  VICTORY
  DEFEAT
  DRAW
}

// ── LEADERBOARD CONFIG ────────────────────────────────────

model LeaderboardChannel {
  id          String          @id @default(cuid())
  guildId     String
  type        LeaderboardType
  channelId   String
  messageId   String?
  enabled     Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([guildId, type])
  @@index([guildId])
}

model LeaderboardSettings {
  id              String    @id @default(cuid())
  guildId         String    @unique
  scheduleHour    Int       @default(9)    // 0-23 UTC
  scheduleMinute  Int       @default(0)
  frequencyHours  Int       @default(24)
  lastPostedAt    DateTime?
  enabled         Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum LeaderboardType {
  TOP_PLAYERS_KD
  TOP_PLAYERS_WINS
  TOP_PLAYERS_ELO
  TOP_ALLIANCES_ELO
  TOP_ALLIANCES_WINS
  TOP_ALLIANCES_RANK
}

