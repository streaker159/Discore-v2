generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Guild {
  id                       String           @id
  defaultGame              String?
  timezone                 String           @default("UTC")
  allianceName             String?
  allianceLogo             String?
  themeColor               String           @default("#1a7a9e")
  scoreboardChan           String?
  adminLogChan             String?
  premiumNoticeChan        String?
  battleSignupChan         String?
  language                 String           @default("en")
  customFooter             String?
  scoreboardManagerRoleId  String?
  disAdminRoleId           String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  allianceCode             String?          @unique
  discoreAppealRoleId      String?
  discoreManagerRoleId     String?
  discoreMutedRoleId       String?
  logChannelId             String?
  maintainRolesAndChannels Boolean          @default(true)
  moderationLogChannelId   String?
  appealChannelId          String?
  appealCategoryId         String?
  eventChannelId           String?
  suggestionChannelId         String?
  suggestionDefaultDuration   Int               @default(7)
  suggestionShowVoters        Boolean           @default(false)
  suggestionRequireReview     Boolean           @default(false)
  suggestionAllowImages       Boolean           @default(true)
  suggestionCreateThreads     Boolean           @default(true)
  suggestionManagerRoleId     String?
  suggestionMaxPerUser        Int               @default(5)
  supportChannelId            String?
  adminReportsChannelId    String?
  publicSuggestionVoters   Boolean          @default(false)
  onboardingSentAt         DateTime?        @db.Timestamptz(6)
  onboardingCompletedAt    DateTime?        @db.Timestamptz(6)
  onboardingSkippedAt      DateTime?        @db.Timestamptz(6)
  onboardingChannelId      String?
  announcementChannelId    String?
  aiWelcomeChannelId       String?
  automodEnabled           Boolean          @default(true)
  automodReviewChannelId   String?
  automodDefaultAction     AutoModAction    @default(REVIEW)
  appeals                  Appeal[]
  auditLogs                AuditLog[]
  autoModCases             AutoModCase[]
  autoModRules             AutoModRule[]
  battleSignups            BattleSignup[]
  events                   Event[]
  premium                  GuildPremium?
  moderationCases          ModerationCase[]
  scoreboards              Scoreboard[]
  suggestions              Suggestion[]
  userActivities           UserActivity[]

  @@index([id])
  @@index([allianceCode])
}

model GuildPremium {
  id                    String        @id @default(cuid())
  guildId               String        @unique
  tier                  Tier          @default(FREE)
  method                PremiumMethod
  stripeSubId           String?
  code                  String?
  expiresAt             DateTime?
  grantedBy             String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  entitlementId         String?
  monthlyAiAllowance    Int           @default(0)
  monthlyAiUsed         Int           @default(0)
  monthlyAiPeriodStart  DateTime?     @db.Timestamptz(6)
  monthlyAiPeriodEnd    DateTime?     @db.Timestamptz(6)
  extraAiCredits        Int           @default(0)
  serverDailyAiLimit    Int           @default(0)
  perUserDailyAiLimit   Int           @default(0)
  cooldownSeconds       Int           @default(0)
  aiEnabled             Boolean       @default(true)
  purchasedAt           DateTime?     @db.Timestamptz(6)
  lastRenewalAt         DateTime?     @db.Timestamptz(6)
  renewalCount          Int           @default(0)
  graceNotifiedAt       DateTime?     @db.Timestamptz(6)
  aiTranslationEnabled  Boolean       @default(false)
  aiWelcomeEnabled      Boolean       @default(false)
  aiWelcomeInstructions String?
  aiImageGenEnabled     Boolean       @default(false)
  perUserDailyImageGenLimit Int       @default(0)
  guild                 Guild         @relation(fields: [guildId], references: [id])

  @@index([guildId])
  @@index([expiresAt])
}

model ProcessedEntitlement {
  id             String   @id @default(cuid())
  guildId        String
  skuId          String
  entitlementId  String   @unique
  creditsGranted Int      @default(0)
  processedAt    DateTime @default(now()) @db.Timestamptz(6)
}

model PremiumCode {
  id          String    @id @default(cuid())
  code        String    @unique
  type        CodeType
  tier        Tier
  maxUses     Int       @default(1)
  uses        Int       @default(0)
  discountPct Int?
  trialDays   Int?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([code])
}

model Scoreboard {
  id                    String                   @id @default(cuid())
  guildId               String
  name                  String
  metric                String                   @default("WIN_LOSS")
  type                  BoardType                @default(USER)
  channelId             String?
  messageId             String?
  theme                 String                   @default("default")
  liveTitle             String?
  description           String?
  season                Int?
  lastLeaderId          String?
  isArchived            Boolean                  @default(false)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  publicId              String?                  @unique
  repairStatus          String                   @default("OK")
  roleImageUrl          String?
  lastUpdatedAt         DateTime?
  archivedAt            DateTime?
  archivedBy            String?
  archiveNote           String?
  hasCategories         Boolean                  @default(false)
  brandingImageUrl      String?
  friendlyArchiveId     String?                  @unique
  restoredFromArchiveId String?
  guild                 Guild                    @relation(fields: [guildId], references: [id])
  actions               ScoreboardAction[]
  entries               ScoreboardEntry[]
  mergeHistories        ScoreboardMergeHistory[]
  userRoleScores        UserRoleScore[]

  @@index([guildId])
}

model ScoreboardScoreType {
  id          String                     @id @default(cuid())
  guildId     String
  scoreboardId String
  name        String
  normalizedName String
  createdAt   DateTime                   @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime                   @default(now()) @updatedAt @db.Timestamptz(6)
  entryStats  ScoreboardEntryTypeStats[]

  @@unique([scoreboardId, normalizedName])
}

model ScoreboardEntryTypeStats {
  id                String              @id @default(cuid())
  guildId           String
  scoreboardId      String
  scoreboardEntryId String
  scoreTypeId       String
  wins              Int                 @default(0)
  losses            Int                 @default(0)
  points            Int                 @default(0)
  createdAt         DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  scoreType         ScoreboardScoreType @relation(fields: [scoreTypeId], references: [id])

  @@unique([scoreboardEntryId, scoreTypeId], map: "ScoreboardEntryTypeStats_entryId_typeId_key")
}

model ScoreboardEntry {
  id                   String     @id @default(cuid())
  scoreboardId         String
  targetId             String
  targetType           BoardType
  wins                 Int        @default(0)
  losses               Int        @default(0)
  points               Int        @default(0)
  winStreak            Int        @default(0)
  lossStreak           Int        @default(0)
  updatedAt            DateTime   @updatedAt
  liveChannelId        String?
  liveMessageId        String?
  sourceScoreboardId   String?
  sourceScoreboardName String?
  targetName           String?
  scoreboard           Scoreboard @relation(fields: [scoreboardId], references: [id])

  @@unique([scoreboardId, targetId])
  @@index([scoreboardId])
  @@index([sourceScoreboardId])
}

model ScoreboardAction {
  id           String     @id @default(cuid())
  scoreboardId String
  targetId     String
  action       String
  delta        Int
  reason       String?
  adminId      String
  createdAt    DateTime   @default(now())
  scoreboard   Scoreboard @relation(fields: [scoreboardId], references: [id])

  @@index([scoreboardId])
}

model ScoreboardMergeHistory {
  id                   String     @id @default(cuid())
  guildId              String
  targetScoreboardId   String
  sourceScoreboardId   String
  sourceScoreboardName String
  mergeOption          String
  mergedBy             String
  entriesMerged        Int        @default(0)
  sourceAction         String
  mergedAt             DateTime   @default(now())
  targetScoreboard     Scoreboard @relation(fields: [targetScoreboardId], references: [id])

  @@index([guildId])
  @@index([targetScoreboardId])
  @@index([sourceScoreboardId])
}

model Game {
  id        String     @id @default(cuid())
  slug      String     @unique
  name      String
  isActive  Boolean    @default(true)
  buildings Building[]
  research  Research[]
  resources Resource[]
  units     Unit[]

  @@index([slug])
}

model Unit {
  id          String    @id @default(cuid())
  gameId      String
  name        String
  aliases     String[]
  doctrine    String?
  category    String?
  description String?
  stats       Json?
  iconUrl     String?
  imageUrl    String?
  isActive    Boolean   @default(true)
  isDraft     Boolean   @default(false)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  game        Game      @relation(fields: [gameId], references: [id])

  @@index([gameId])
}

model Building {
  id          String    @id @default(cuid())
  gameId      String
  name        String
  aliases     String[]
  description String?
  stats       Json?
  iconUrl     String?
  isActive    Boolean   @default(true)
  isDraft     Boolean   @default(false)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  game        Game      @relation(fields: [gameId], references: [id])

  @@index([gameId])
}

model Resource {
  id          String   @id @default(cuid())
  gameId      String
  name        String
  aliases     String[]
  description String?
  iconUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  game        Game     @relation(fields: [gameId], references: [id])

  @@index([gameId])
}

model Research {
  id          String    @id @default(cuid())
  gameId      String
  name        String
  aliases     String[]
  description String?
  stats       Json?
  iconUrl     String?
  isActive    Boolean   @default(true)
  isDraft     Boolean   @default(false)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  game        Game      @relation(fields: [gameId], references: [id])

  @@index([gameId])
}

model BattleSignup {
  id           String              @id @default(cuid())
  guildId      String
  channelId    String
  messageId    String?
  threadId     String?
  captainId    String
  game         String
  title        String?
  description  String?
  mode         String?
  scheduledAt  DateTime
  teamSize     Int
  tagOnCreate  String?
  tagOnStart   String?
  status       SignupStatus        @default(OPEN)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  publicId     String?
  cleanupAfter DateTime?
  guild        Guild               @relation(fields: [guildId], references: [id])
  participants SignupParticipant[]

  @@index([guildId])
}

model SignupParticipant {
  id       String            @id @default(cuid())
  signupId String
  userId   String
  status   ParticipantStatus
  joinedAt DateTime          @default(now())
  signup   BattleSignup      @relation(fields: [signupId], references: [id])

  @@unique([signupId, userId])
}

model Event {
  id                    String                 @id @default(cuid())
  guildId               String
  title                 String
  description           String?
  location              String?
  imageUrl              String?
  thumbnailUrl          String?
  channelId             String
  messageId             String?
  scheduledAt           DateTime
  createdBy             String
  tagOnCreate           Boolean                @default(false)
  tagOnStart            Boolean                @default(false)
  status                EventStatus            @default(DRAFT)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  publicId              String?                @unique
  eventType             String                 @default("EVENT")
  cleanupAfter          DateTime?
  game                  String?
  customTypeName        String?
  timezoneUsed          String?
  reminderBeforeMinutes Int?
  teamSize              Int?
  color                 String?
  tagRoleIds            String[]               @default([])
  eventNumber           Int?                   @unique
  draftedAt             DateTime?              @db.Timestamptz(6)
  dataDeleteAt          DateTime?              @db.Timestamptz(6)
  guild                 Guild                  @relation(fields: [guildId], references: [id])
  notificationLogs      EventNotificationLog[]
  reminders             EventReminder[]
  rsvps                 EventRsvp[]

  @@index([guildId])
  @@index([scheduledAt])
  @@index([status])
  @@index([cleanupAfter])
  @@index([dataDeleteAt])
}

model EventRsvp {
  id        String     @id @default(cuid())
  eventId   String
  userId    String
  status    RsvpStatus
  updatedAt DateTime   @updatedAt
  event     Event      @relation(fields: [eventId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
}

/// *
///  * Tracks each notification type that has been sent for an event.
///  * Unique constraint on (eventId, notificationType) prevents double-sends
///  * even if the bot restarts or the job fires twice.
model EventNotificationLog {
  id               String   @id @default(cuid())
  eventId          String
  guildId          String
  notificationType String
  channelId        String?
  messageId        String?
  roleId           String?
  sentAt           DateTime @default(now())
  event            Event    @relation(fields: [eventId], references: [id])

  @@unique([eventId, notificationType])
  @@index([eventId])
}

/// *
///  * Per-user personal reminders set via the "Remind Me" button.
model EventReminder {
  id        String    @id @default(cuid())
  eventId   String
  userId    String
  remindAt  DateTime
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  event     Event     @relation(fields: [eventId], references: [id])

  @@unique([eventId, userId])
  @@index([remindAt])
  @@index([eventId])
}

model Suggestion {
  id           String           @id @default(cuid())
  guildId      String
  authorId     String
  content      String
  imageUrl     String?
  status       SuggestionStatus @default(OPEN)
  channelId    String
  messageId    String?
  threadId     String?
  expiresAt    DateTime?
  closesAt     DateTime?
  dataDeleteAt DateTime?
  createdAt    DateTime         @default(now())
  publicId     String?          @unique
  title        String           @default("")
  updatedAt    DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  approvedBy   String?
  approvedAt   DateTime?        @db.Timestamptz(6)
  deniedBy     String?
  deniedAt     DateTime?        @db.Timestamptz(6)
  closedBy     String?
  closedAt     DateTime?        @db.Timestamptz(6)
  adminNote    String?
  showVoters   Boolean          @default(false)
  category     String           @default("GENERAL")
  guild        Guild            @relation(fields: [guildId], references: [id])
  votes        SuggestionVote[]

  @@index([guildId])
  @@index([dataDeleteAt])
  @@index([closesAt])
}

model SuggestionVote {
  id           String     @id @default(cuid())
  suggestionId String
  userId       String
  type         VoteType
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id])

  @@unique([suggestionId, userId])
}

model PlayerProfile {
  id                      String             @id @default(cuid())
  discordId               String             @unique
  gameUsername            String?
  game                    String?            @default("supremacy-ww3")
  currentAlliance         String?
  currentAllianceTag      String?
  currentAllianceJoinedAt DateTime?
  inGameRank              String?
  level                   Int?
  xpCurrent               Int?
  xpMax                   Int?
  kdRatio                 Float?
  unitsKilled             Int?
  unitsLost               Int?
  provincesTaken          Int?
  provincesLost           Int?
  gamesJoined             Int?
  soloVictories           Int?
  coalitionVictories      Int?
  overallScore            Int?
  overallRank             Int?
  economicRank            Int?
  militaryRank            Int?
  memberSince             String?
  lastOnline              String?
  playedOnPC              Int?
  playedOnMobile          Int?
  role                    String?
  playstyle               String?
  discoreElo              Int                @default(1000)
  winRate                 Float?
  performanceScore        Int?
  combatStyle             String?
  isPublic                Boolean            @default(true)
  profileImageUrl         String?
  screenshotUrls          String[]
  lastUpdateAt            DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  allianceHistory         AllianceHistory[]
  updateLogs              ProfileUpdateLog[]

  @@index([discordId])
}

model AllianceHistory {
  id           String        @id @default(cuid())
  playerId     String
  allianceName String
  allianceTag  String?
  game         String
  joinedAt     DateTime
  leftAt       DateTime?
  player       PlayerProfile @relation(fields: [playerId], references: [id])

  @@index([playerId])
}

model ProfileUpdateLog {
  id        String        @id @default(cuid())
  playerId  String
  updatedAt DateTime      @default(now())
  player    PlayerProfile @relation(fields: [playerId], references: [id])

  @@index([playerId])
}

model AllianceProfile {
  id                                                String                @id @default(cuid())
  name                                              String
  tag                                               String
  game                                              String
  logoUrl                                           String?
  bannerUrl                                         String?
  description                                       String?
  discordInvite                                     String?
  country                                           String?
  tags                                              String[]
  ownerId                                           String?
  managerRoleId                                     String?
  officialId                                        String?
  officialRank                                      Int?
  officialElo                                       Int?
  officialWins                                      Int?
  officialLosses                                    Int?
  officialMembers                                   Int?
  officialMaxMembers                                Int?
  founded                                           String?
  discoreRank                                       Int?
  discoreElo                                        Int                   @default(1000)
  discoreWins                                       Int                   @default(0)
  discoreLosses                                     Int                   @default(0)
  winRate                                           Float?
  seasonRecord                                      String?
  isPublic                                          Boolean               @default(true)
  screenshotUrls                                    String[]
  lastUpdateAt                                      DateTime?
  createdAt                                         DateTime              @default(now())
  updatedAt                                         DateTime              @updatedAt
  recentMatches                                     AllianceRecentMatch[]
  updateLogs                                        AllianceUpdateLog[]

  @@unique([tag, game])
  @@index([game])
}

model AllianceRecentMatch {
  id           String          @id @default(cuid())
  allianceId   String
  opponentName String
  opponentTag  String?
  opponentLogo String?
  result       MatchResult
  occurredAt   DateTime        @default(now())
  alliance     AllianceProfile @relation(fields: [allianceId], references: [id])

  @@index([allianceId])
}

model AllianceUpdateLog {
  id         String          @id @default(cuid())
  allianceId String
  updatedBy  String
  updatedAt  DateTime        @default(now())
  alliance   AllianceProfile @relation(fields: [allianceId], references: [id])

  @@index([allianceId])
}

model LeaderboardChannel {
  id        String          @id @default(cuid())
  guildId   String
  type      LeaderboardType
  channelId String
  messageId String?
  enabled   Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([guildId, type])
  @@index([guildId])
}

model LeaderboardSettings {
  id             String    @id @default(cuid())
  guildId        String    @unique
  scheduleHour   Int       @default(9)
  scheduleMinute Int       @default(0)
  frequencyHours Int       @default(24)
  lastPostedAt   DateTime?
  enabled        Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AiCredits {
  id        String   @id @default(cuid())
  guildId   String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model AiUsageLog {
  id          String   @id @default(cuid())
  guildId     String
  userId      String
  requestType String
  cost        Int
  createdAt   DateTime @default(now())

  @@index([guildId])
}

model AuditLog {
  id        String   @id @default(cuid())
  guildId   String
  action    String
  actorId   String
  targetId  String?
  meta      Json?
  createdAt DateTime @default(now())
  guild     Guild    @relation(fields: [guildId], references: [id])

  @@index([guildId])
}

model MatchWatcher {
  id         String   @id @default(cuid())
  guildId    String
  channelId  String
  createdBy  String
  game       String
  mode       String?
  maxPlayers Int?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([guildId])
  @@index([game, isActive])
}

model BattleReminder {
  id        String   @id @default(cuid())
  signupId  String
  userId    String
  remindAt  DateTime
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([signupId, userId])
  @@index([remindAt, sent])
}

model UserActivity {
  id                  String    @id @default(cuid())
  guildId             String
  userId              String
  lastMessageAt       DateTime?
  lastReactionAt      DateTime?
  lastInteractionAt   DateTime?
  lastActiveAt        DateTime?
  activeDayStreak     Int       @default(0)
  lastActiveDate      DateTime?
  mostActiveChannelId String?
  mostUsedReaction    String?
  updatedAt           DateTime  @updatedAt
  guild               Guild     @relation(fields: [guildId], references: [id])

  @@unique([guildId, userId])
  @@index([guildId, userId])
  @@index([lastActiveAt])
}

model ModerationCase {
  id              String            @id @default(cuid())
  publicId        String            @unique
  guildId         String
  userId          String
  moderatorId     String
  actionType      ModActionType
  reason          String
  durationSeconds Int?
  expiresAt       DateTime?
  status          CaseStatus        @default(ACTIVE)
  appealStatus    AppealStatus?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  revokedAt       DateTime?
  revokedBy       String?
  staffNote       String?
  appeals         Appeal[]
  guild           Guild             @relation(fields: [guildId], references: [id])
  roleSnapshot    UserRoleSnapshot?

  @@index([guildId])
  @@index([userId])
  @@index([publicId])
  @@index([status])
  @@index([expiresAt])
  @@index([appealStatus])
}

model Appeal {
  id         String         @id @default(cuid())
  publicId   String         @unique
  caseId     String
  guildId    String
  userId     String
  appealText String
  status     AppealStatus   @default(OPEN)
  channelId  String?
  createdAt  DateTime       @default(now())
  closedAt   DateTime?
  closedBy   String?
  outcome    String?
  staffNotes String?
  case       ModerationCase @relation(fields: [caseId], references: [id])
  guild      Guild          @relation(fields: [guildId], references: [id])

  @@index([caseId])
  @@index([guildId])
  @@index([publicId])
  @@index([status])
}

model UserRoleSnapshot {
  id           String         @id @default(cuid())
  guildId      String
  userId       String
  caseId       String         @unique
  roleIds      String[]
  createdAt    DateTime       @default(now())
  cleanupAfter DateTime?
  case         ModerationCase @relation(fields: [caseId], references: [id])

  @@index([caseId])
  @@index([cleanupAfter])
}

model AutoModRule {
  id                String        @id @default(cuid())
  guildId           String
  name              String?
  phrase            String
  matchType         MatchType     @default(CONTAINS)
  action            AutoModAction @default(REVIEW)
  severity          String        @default("MEDIUM")
  enabled           Boolean       @default(true)
  exemptRoleIds     Json?
  ignoredChannelIds Json?
  reviewChannelId   String?
  timeoutSeconds    Int?
  deleteMessage     Boolean       @default(false)
  userMessage       String?       @db.Text
  appealEnabled     Boolean       @default(false)
  triggerCount      Int           @default(0)
  lastTriggeredAt   DateTime?
  createdBy         String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  cases             AutoModCase[]
  guild             Guild         @relation(fields: [guildId], references: [id])

  @@index([guildId])
  @@index([enabled])
}

model AutoModCase {
  id               String        @id @default(cuid())
  publicId         String        @unique
  guildId          String
  userId           String
  channelId        String
  messageId        String?
  ruleId           String
  matchedText      String?
  messageExcerpt   String
  actionTaken      AutoModAction
  status           ReviewStatus  @default(PENDING)
  reviewMessageId  String?
  resolutionAction String?
  moderationCaseId String?
  cleanupAfter     DateTime?
  createdAt        DateTime      @default(now())
  reviewedAt       DateTime?
  reviewedBy       String?
  guild            Guild         @relation(fields: [guildId], references: [id])
  rule             AutoModRule   @relation(fields: [ruleId], references: [id])

  @@index([guildId])
  @@index([status])
  @@index([cleanupAfter])
}

model AiUsage {
