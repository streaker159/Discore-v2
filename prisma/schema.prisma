  answerJson           Json?
  selectedOptionValues String[] @default([])
  selectedRoleIds      String[] @default([])
  fileRefs             Json?
  createdAt            DateTime @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([applicationId])
}

model OnboardingStaffNote {
  id            String    @id @default(cuid())
  applicationId String
  guildId       String
  authorId      String
  noteText      String
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime? @db.Timestamptz(6)
  deletedAt     DateTime? @db.Timestamptz(6)

  @@index([applicationId])
  @@index([guildId])
}

model OnboardingDecisionLog {
  id            String   @id @default(cuid())
  applicationId String
  guildId       String
  action        String
  actorId       String
  reason        String?
  detailsJson   Json?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  @@index([applicationId])
  @@index([guildId])
}

model OnboardingApplicationTranscript {
  id             String   @id @default(cuid())
  applicationId  String
  guildId        String
  threadId       String?
  fileName       String
  contentType    String   @default("text/plain")
  storageRef     String?
  transcriptText String?
  messageCount   Int      @default(0)
  createdBy      String
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  @@index([applicationId])
  @@index([guildId])
}

model OnboardingSession {
  id                String   @id @default(cuid())
  guildId           String
  applicationTypeId String?
  applicantId       String
  applicationId     String?
  currentPage       Int      @default(0)
  stateJson         Json?
  expiresAt         DateTime @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([guildId])
  @@index([applicantId])
  @@index([expiresAt])
}

model OnboardingPermissionRole {
  id             String   @id @default(cuid())
  guildId        String
  roleId         String
  canManage      Boolean  @default(false)
  canBuildForms  Boolean  @default(false)
  canReview      Boolean  @default(false)
  canApproveDeny Boolean  @default(false)
  canOpenThreads Boolean  @default(false)
  canDownload    Boolean  @default(false)
  canDelete      Boolean  @default(false)
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  @@unique([guildId, roleId])
  @@index([guildId])
  @@index([roleId])
}
